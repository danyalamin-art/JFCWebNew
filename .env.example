# Server port (default 3000)
PORT=3000

# Admin dashboard password (required for production-like testing)
ADMIN_PASSWORD=jfc-admin

# OMDb API key — primary source for auto movie details in admin
# Get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Optional: Gemini fallback if OMDb fails (not required when OMDB_API_KEY is set)
# GEMINI_API_KEY=

# Optional public URL when deployed
# APP_URL=http://localhost:3000
